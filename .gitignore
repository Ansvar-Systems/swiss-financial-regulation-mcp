# ═══════════════════════════════════════════════════════════════════════════
# GIT IGNORE
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# NODE
# ───────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build output
dist/

# Test coverage
coverage/

# npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────────────────────────────────────────────────────────────────────────
# DATA
# ───────────────────────────────────────────────────────────────────────────

# Database — build artifact, regenerated from seed data via `npm run build:db`
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Source data downloads (if any)
data/*.csv
data/*.json.gz
data/*.zip

# ───────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ───────────────────────────────────────────────────────────────────────────

# Environment variables
.env
.env.local
.env.*.local

# ───────────────────────────────────────────────────────────────────────────
# IDE
# ───────────────────────────────────────────────────────────────────────────

# VS Code
.vscode/
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# ───────────────────────────────────────────────────────────────────────────
# OS
# ───────────────────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ───────────────────────────────────────────────────────────────────────────
# MISC
# ───────────────────────────────────────────────────────────────────────────

# TypeScript incremental compilation
*.tsbuildinfo

# Lock files (keep package-lock.json, ignore others)
yarn.lock
pnpm-lock.yaml

# Logs
logs/

# Temporary files
tmp/
temp/
*.tmp
.serena/
.claude/
.vercel
database.db
reports/

# === Standard MCP patterns (appended by apply-golden-standard.sh) ===
# ═══════════════════════════════════════════════════════════════════════════
# GIT IGNORE — MCP standard template (managed by apply-golden-standard.sh)
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# NODE
# ───────────────────────────────────────────────────────────────────────────
node_modules/
dist/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────────────────────────────────────────────────
# DATA — build artifacts, regenerated from upstream by `npm run ingest` + `npm run build:db`
# ───────────────────────────────────────────────────────────────────────────

# SQLite database (built at deploy time)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Ingested seed JSONs (built by ingestion scripts; per source-attribution
# standard, NO committed corpora — DB is built from upstream at deploy)
data/seed/
data/seed_paid/

# Downloaded source archives (cache for re-runs of ingestion)
data/cache/

# Bulk download artifacts from upstream
*.tgz
*.tar.gz
*.tar.bz2
*.zip
*.csv
*.json.gz

# Generated coverage / census artifacts (regenerated each build)
data/census.json
data/relevant-statutes.json
data/validation-statutes.json
data/eu-references-analysis.json

# ───────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ───────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ───────────────────────────────────────────────────────────────────────────
# IDE / TOOLING
# ───────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
*.swp
*.bak

# ───────────────────────────────────────────────────────────────────────────
# CLAUDE / AGENT WORK
# ───────────────────────────────────────────────────────────────────────────
.claude/
